# Engine outputs / audit logs (per-project, never committed)
audit/
.swarm/
**/coord/packets/*/responses/
**/coord/packets/*/audit/

# IDE
.idea/
.vscode/
*.swp

# Windows / PowerShell pollution (ModuleAnalysisCache when $LOCALAPPDATA not set)
/Microsoft/

# pip cache pollution when --cache-dir not set during tool runs
/pip/

# Local dev_loop runtime state (the seed state.json is tracked; ad-hoc runtime
# overrides are not. Uncomment if you want to keep the seed only.)
# coord/dev_loop/state.runtime.json

# Observer runtime artifacts (#20): created by `harness observer init`,
# updated by cycles, ack'd by operator.  Per-machine state, not committed.
coord/observer/

# Heartbeat (HEARTBEAT): runtime pulse, per-machine, not committed.
coord/dev_loop/heartbeat.json

# Budget ledger (BUDGET-METER): runtime cost tracking, per-machine, not committed.
coord/dev_loop/budget_ledger.jsonl
coord/dev_loop/budget_archive/
