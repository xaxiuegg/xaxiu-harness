# xaxiu-harness .env template
#
# Copy this file to `.env` in this directory, then fill in the keys
# you have.  You don't need ALL keys — only the providers you plan
# to dispatch to.
#
# Easiest way to populate: launch the keys UI:
#
#     python -m harness keys serve
#
# That opens a browser form where you can paste keys, test each one,
# and save securely to .env (with 0600 file mode on POSIX systems).
#
# ---------------------------------------------------------------
# Provider API keys (at least one required)
# ---------------------------------------------------------------

# Kimi (Moonshot) — for kimi-via-claude engine + swarm/kimi-api +
# claude-kimi wrapper.  Get one at https://platform.moonshot.cn/
KIMI_API_KEY=

# MiMo (Xiaomi) — for mimo-via-claude engine + claude-mimo wrapper.
# Token Plan keys start with tp-; PAYG keys with mp-.  Both work.
# Get one at https://mimo.xiaomi.com/
MIMO_API_KEY=

# DeepSeek — for deepseek-via-claude + swarm/deepseek + direct httpx +
# claude-deepseek wrapper.  Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ---------------------------------------------------------------
# Optional providers
# ---------------------------------------------------------------

# Anthropic (only needed if you want direct Anthropic-API dispatch
# alongside Pattern B; Pattern B routes through Claude Code's
# subscription so this key is NOT required for Pattern B to work)
ANTHROPIC_API_KEY=

# Gemini (Google)
GEMINI_API_KEY=

# Qwen (Alibaba DashScope) — for the claude-qwen wrapper
DASHSCOPE_API_KEY=

# GLM (Zhipu z.ai) — for the claude-glm wrapper
GLM_API_KEY=

# ---------------------------------------------------------------
# Multi-key pools (optional — for rate-limit pooling or failover)
# ---------------------------------------------------------------
# Each provider supports KIMI_API_KEY_1, KIMI_API_KEY_2, ... up to _4.
# The harness automatically rotates / fails over between them.
# See spec/engine-routing-empirical.md for routing strategy details.
#
# Example: two Kimi keys for higher rate limits:
# KIMI_API_KEY_1=...
# KIMI_API_KEY_2=...
#
# Optional per-key labels for the keys UI:
# KIMI_API_KEY_LABEL_1=personal
# KIMI_API_KEY_LABEL_2=backup
